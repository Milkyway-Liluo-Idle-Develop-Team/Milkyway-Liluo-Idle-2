# Application
APP_ENV=development
LOG_LEVEL=debug
LOG_FORMAT=text
# LOG_FILE=latest.log

# HTTP server
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=15s
# Comma-separated allowed origins, "*" means any. Tighten in prod.
HTTP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Database (SQLite, pure-Go driver — no CGO required)
# Examples:
#   file:data.db?_pragma=foreign_keys(1)
#   file:./var/app.db?_pragma=foreign_keys(1)
#   file::memory:?cache=shared    (in-memory, dev/tests only)
DATABASE_URL=file:data.db?_pragma=foreign_keys(1)
DATABASE_MAX_OPEN_CONNS=4
DATABASE_MAX_IDLE_CONNS=4
DATABASE_CONN_MAX_LIFETIME=0
DATABASE_AUTO_MIGRATE=true

# Auth
AUTH_SESSION_TTL=720h
AUTH_COOKIE_NAME=sid
AUTH_COOKIE_DOMAIN=
# Set true behind HTTPS in prod.
AUTH_COOKIE_SECURE=false
# "lax" | "strict" | "none". For "none", AUTH_COOKIE_SECURE must be true.
AUTH_COOKIE_SAMESITE=lax
AUTH_BCRYPT_COST=12

# WebSocket
WS_CODEC=json
WS_MAX_MESSAGE_SIZE=65536
WS_WRITE_TIMEOUT=10s
WS_PING_INTERVAL=30s
WS_SEND_BUFFER=64
WS_ALLOW_ANONYMOUS=false
WS_SESSION_GRACE_PERIOD=30s
WS_GAME_LOOP_TICK=50ms
